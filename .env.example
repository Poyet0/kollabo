# ==================================================
# KOLLABO — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans le dépôt
# ==================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ---- Base de données (Postgres direct via Drizzle) ----
DATABASE_URL=postgres://postgres.[project-id]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL_UNPOOLED=postgres://postgres.[project-id]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# ---- Auth ----
NEXTAUTH_SECRET=your-nextauth-secret-32-chars-min
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- CinetPay ----
CINETPAY_API_KEY=your-cinetpay-api-key
CINETPAY_SITE_ID=your-cinetpay-site-id
CINETPAY_SECRET_KEY=your-cinetpay-secret-key
CINETPAY_WEBHOOK_SECRET=your-webhook-secret

# ---- Wave Direct API ----
WAVE_API_KEY=your-wave-api-key
WAVE_WEBHOOK_SECRET=your-wave-webhook-secret

# ---- Resend (emails) ----
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=KOLLABO <noreply@kollabo.app>

# ---- Africa's Talking (SMS) ----
AT_API_KEY=your-africas-talking-api-key
AT_USERNAME=your-africas-talking-username
AT_SENDER_ID=KOLLABO

# ---- Yousign (signature électronique) ----
YOUSIGN_API_KEY=your-yousign-api-key
YOUSIGN_BASE_URL=https://api-sandbox.yousign.app/v3

# ---- Cloudflare R2 (stockage fichiers) ----
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_AVATARS=kollabo-avatars
R2_BUCKET_PROOFS=kollabo-proofs
R2_BUCKET_DOCUMENTS=kollabo-documents
R2_PUBLIC_URL=https://your-bucket.your-subdomain.r2.dev

# ---- PostHog (analytics) ----
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ---- Sentry (monitoring) ----
SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
SENTRY_ORG=kollabo
SENTRY_PROJECT=kollabo-web

# ---- Instagram Graph API ----
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret

# ---- TikTok for Developers ----
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# ---- YouTube Data API v3 ----
YOUTUBE_CLIENT_ID=your-google-client-id
YOUTUBE_CLIENT_SECRET=your-google-client-secret

# ---- Feature flags ----
NEXT_PUBLIC_ENABLE_WAVE=true
NEXT_PUBLIC_ENABLE_ORANGE_MONEY=true
NEXT_PUBLIC_ENABLE_MTN_MONEY=false
